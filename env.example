# Seller wallet (base58) — input to /payment-required/enrich only
SELLER_WALLET=

# Facilitator base (include /api/v1/facilitator)
FACILITATOR_URL=https://preview.ipay.sh/api/v1/facilitator

# Public URL of this API (used when generating the 402 payment body)
RESOURCE_URL=https://your-app.vercel.app/api/v1/weather?city=Atlanta

# Path to enriched 402 JSON (generated by npm run enrich)
PAYMENT_BODY_PATH=payment-body.devnet.json

# Price in USDC micro-units (50000 = 0.05 USDC — recommended minimum for exact rail fee math)
PAYMENT_AMOUNT=50000

# Local dev server port
PORT=3000
